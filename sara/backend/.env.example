# SARA backend runtime config (WS0-WP1)
# Copy to .env on the Pi 5. All values have safe defaults; nothing here is secret yet.

# Port the SARA backend listens on. Default 3005 to avoid clashing with the
# existing NEURO backend on 3001.
SARA_PORT=3005

# --- Home Assistant telemetry bridge (WS3-WP1) ---
# All optional. If unset, the telemetry bridge stays idle and SARA falls back honestly
# (location comes from seed, /api/state reports telemetry.available=false). HA is a
# telemetry BUS only — these signals feed the shared state model, they do not drive
# decisions or view selection.
#
# Base URL of your Home Assistant instance (no trailing slash) and a long-lived access
# token (HA profile -> Long-Lived Access Tokens). Both are required to go live.
# SARA_HA_BASE_URL=http://homeassistant.local:8123
# SARA_HA_TOKEN=

# Bounded v0 signal scope: exactly three slots, each naming ONE HA entity to read.
# Set the ones you have; missing slots are reported as a "partial" telemetry snapshot.
#   location    — a person/device_tracker entity (state is a zone: home / not_home / <zone>)
#   presence    — a binary_sensor or person entity (on/off/home/away -> present true/false)
#   environment — any sensor (e.g. temperature) — one signal to prove the seam
# SARA_HA_LOCATION_ENTITY=person.nick
# SARA_HA_PRESENCE_ENTITY=binary_sensor.office_occupancy
# SARA_HA_ENV_ENTITY=sensor.office_temperature

# Poll interval and per-request timeout (ms). Defaults: 30000 / 4000.
# SARA_HA_POLL_MS=30000
# SARA_HA_TIMEOUT_MS=4000
