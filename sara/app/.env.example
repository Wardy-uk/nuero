# SARA light-touch app — build-time config (Vite reads VITE_* at build).
#
# Production (Netlify build): point at the NEURO brain's Tailscale Serve HTTPS URL.
# Tailnet-only — every device that uses SARA is on Tailscale, so the brain is never
# exposed to the public internet. Example (replace with the Pi 5's real ts.net name):
#   VITE_API_URL=https://pi5.tailXXXX.ts.net
VITE_API_URL=

# Vault API key — sent as X-Api-Key on /api/vault* routes (brain re-indexes on write).
VITE_VAULT_API_KEY=

# Dev only: where `vite` proxies /api to (defaults to http://localhost:3001, the NEURO backend).
# NEURO_BACKEND_URL=http://localhost:3001
