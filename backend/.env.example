# Claude AI
ANTHROPIC_API_KEY=

# Jira Service Management (optional — n8n ingest path is preferred)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NT

# Obsidian vault path (on the Pi)
OBSIDIAN_VAULT_PATH=/home/nick/vault

# Microsoft 365 (optional — for calendar, inbox, tasks)
MS_CLIENT_ID=
MS_TENANT_ID=

# n8n
N8N_API_URL=https://n8n-dashboard.nurtur-ai.app
N8N_API_KEY=

# Web Push (VAPID keys — one-time setup)
# Step 1: SSH into Pi, cd to nick-agent/backend, run: npx web-push generate-vapid-keys
# Step 2: Paste the two keys below into Pi .env, then: pm2 restart neuro
# Step 3: Open NEURO on iPhone/iPad (must be installed as PWA) → Settings → Enable Notifications
# Step 4: Use "Send Test Notification" in Settings to verify
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Security
INGEST_SECRET=
VAULT_API_KEY=

# QA dashboard webhook
QA_WEBHOOK_BASE=

# Ollama (local LLM fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Claude model override
CLAUDE_MODEL=claude-sonnet-4-20250514

# Plan configuration
PLAN_START_DATE=2026-03-16
PLAN_DURATION_DAYS=90

# Strava integration (optional — for activity context in journal prompts)
# Setup:
# 1. Go to https://www.strava.com/settings/api
# 2. Create an app — set "Authorization Callback Domain" to your Tailscale Pi hostname
#    e.g. raspberrypi.tail12345.ts.net
# 3. Set STRAVA_REDIRECT_URI to http://[your-pi-tailscale-hostname]:3001/api/strava/callback
# 4. Paste Client ID and Client Secret below
# 5. In NEURO Settings, tap "Connect Strava" and authorise
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Apple Health Bridge (iOS Shortcuts webhook)
# The iOS Shortcut POSTs to POST /api/health/ingest with this JSON body:
# {
#   "date": "2026-03-21",          (optional — defaults to today)
#   "hrv": 45,                     (ms — Heart Rate Variability, average overnight)
#   "rhr": 52,                     (bpm — Resting Heart Rate)
#   "sleepDuration": 7.2,          (hours — total sleep)
#   "sleepDeep": 1.4,              (hours — Deep sleep)
#   "sleepRem": 1.8,               (hours — REM sleep)
#   "sleepAwake": 0.3,             (hours — awake during sleep window)
#   "sleepEfficiency": 91,         (percentage)
#   "steps": 8432,                 (daily step count)
#   "activeEnergy": 420,           (kcal)
#   "respiratoryRate": 15.2,       (breaths per minute, overnight average)
#   "vo2max": 48.3,                (mL/kg/min — if available)
#   "bodyWeight": 84.5             (kg — if logged)
# }
# Authorization: Bearer [INGEST_SECRET]
# All fields are optional — send whatever Health data is available

# Server
PORT=3001
