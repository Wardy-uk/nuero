# ── AI Configuration (Phase 3) ──
# AI_MODE controls what AI backends are used:
#   off           — no AI, deterministic rules only
#   ollama-only   — local Ollama only, never call cloud (DEFAULT)
#   hybrid        — Ollama default, escalate to OpenAI when justified
#   critical-only — OpenAI only for explicitly critical tasks
AI_MODE=ollama-only

# SARA suggestion mode (suggest = propose actions, off = no suggestions)
SARA_MODE=suggest

# Ollama (local LLM — primary, on Pi 5)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Pi 4 Background Worker (offloads email triage, imports, journals, transcripts)
PI4_WORKER_ENABLED=false
PI4_WORKER_URL=http://100.69.158.50:3002
PI4_WORKER_SECRET=
PI4_WORKER_TIMEOUT_MS=60000

# OpenRouter (cloud LLM — handles heavy/interactive tasks)
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_DAILY_CALL_LIMIT=100
OPENROUTER_DAILY_TOKEN_LIMIT=100000
OPENROUTER_MAX_ESCALATIONS_PER_HOUR=20
# Comma-separated task types allowed for OpenRouter (or 'all')
OPENROUTER_ALLOWED_TASKS=all
# Tasks types that qualify as 'critical' (for critical-only mode)
OPENROUTER_CRITICAL_ONLY_TYPES=escalation_reasoning,sla_ambiguity,cross_context_synthesis,transcript_processing

# Jira Service Management (optional — n8n ingest path is preferred)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NT

# Obsidian vault path (on the Pi)
OBSIDIAN_VAULT_PATH=/home/nick/vault

# Microsoft 365 (optional — for calendar, inbox, tasks)
MS_CLIENT_ID=
MS_TENANT_ID=

# n8n
N8N_API_URL=https://n8n-dashboard.nurtur-ai.app
N8N_API_KEY=

# Web Push (VAPID keys — one-time setup)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Security
INGEST_SECRET=
VAULT_API_KEY=

# NEURO API token — machine-to-machine auth for n8n / scheduled jobs.
# Callers pass this as header `X-Neuro-Api-Token`. Separate from NEURO_PIN so
# the interactive PIN can rotate without breaking automation. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEURO_API_TOKEN=

# QA dashboard webhook
QA_WEBHOOK_BASE=

# Plan configuration
PLAN_START_DATE=2026-03-16
PLAN_DURATION_DAYS=90

# Strava integration (optional)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Server
PORT=3001
