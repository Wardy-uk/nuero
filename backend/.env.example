# ── AI Configuration (Phase 3) ──
# AI_MODE controls what AI backends are used:
#   off           — no AI, deterministic rules only
#   ollama-only   — local Ollama only, never call cloud (DEFAULT)
#   hybrid        — Ollama default, escalate to OpenAI when justified
#   critical-only — OpenAI only for explicitly critical tasks
AI_MODE=ollama-only

# SARA suggestion mode (suggest = propose actions, off = no suggestions)
SARA_MODE=suggest

# Ollama (local LLM — primary, on Pi 5)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Pi 4 Background Worker (offloads email triage, imports, journals, transcripts)
PI4_WORKER_ENABLED=false
PI4_WORKER_URL=http://100.69.158.50:3002
PI4_WORKER_SECRET=
PI4_WORKER_TIMEOUT_MS=60000

# OpenAI (cloud LLM — optional escalation)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_CALL_LIMIT=50
OPENAI_DAILY_TOKEN_LIMIT=50000
OPENAI_MAX_ESCALATIONS_PER_HOUR=10
# Comma-separated task types allowed for OpenAI (or 'all')
OPENAI_ALLOWED_TASKS=all
# Tasks types that qualify as 'critical' (for critical-only mode)
OPENAI_CRITICAL_ONLY_TYPES=escalation_reasoning,sla_ambiguity,cross_context_synthesis,transcript_processing

# ── Anthropic (DEPRECATED — no longer used in active architecture) ──
# ANTHROPIC_API_KEY is no longer used for any runtime AI calls.
# Legacy reference only. Remove when confirmed unnecessary.
ANTHROPIC_API_KEY=

# Jira Service Management (optional — n8n ingest path is preferred)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NT

# Obsidian vault path (on the Pi)
OBSIDIAN_VAULT_PATH=/home/nick/vault

# Microsoft 365 (optional — for calendar, inbox, tasks)
MS_CLIENT_ID=
MS_TENANT_ID=

# n8n
N8N_API_URL=https://n8n-dashboard.nurtur-ai.app
N8N_API_KEY=

# Web Push (VAPID keys — one-time setup)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Security
INGEST_SECRET=
VAULT_API_KEY=

# QA dashboard webhook
QA_WEBHOOK_BASE=

# Plan configuration
PLAN_START_DATE=2026-03-16
PLAN_DURATION_DAYS=90

# Strava integration (optional)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# Server
PORT=3001
