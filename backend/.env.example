# Claude AI
ANTHROPIC_API_KEY=

# Jira Service Management (optional — n8n ingest path is preferred)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NT

# Obsidian vault path (on the Pi)
OBSIDIAN_VAULT_PATH=/home/nick/vault

# Microsoft 365 (optional — for calendar, inbox, tasks)
MS_CLIENT_ID=
MS_TENANT_ID=

# n8n
N8N_API_URL=https://n8n-dashboard.nurtur-ai.app
N8N_API_KEY=

# Web Push (VAPID keys — one-time setup)
# Step 1: SSH into Pi, cd to nick-agent/backend, run: npx web-push generate-vapid-keys
# Step 2: Paste the two keys below into Pi .env, then: pm2 restart neuro
# Step 3: Open NEURO on iPhone/iPad (must be installed as PWA) → Settings → Enable Notifications
# Step 4: Use "Send Test Notification" in Settings to verify
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Security
INGEST_SECRET=
VAULT_API_KEY=

# QA dashboard webhook
QA_WEBHOOK_BASE=

# Ollama (local LLM fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Claude model override
CLAUDE_MODEL=claude-sonnet-4-20250514

# Plan configuration
PLAN_START_DATE=2026-03-16
PLAN_DURATION_DAYS=90

# Server
PORT=3001
